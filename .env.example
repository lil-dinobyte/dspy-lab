# Copia este archivo a .env y rellena los valores (no subas .env a git).

# Backend por defecto para `configure_lm()` / API: openai | ollama
DSPY_LM_BACKEND=openai

# OpenAI (LiteLLM; requiere OPENAI_API_KEY si usas openai)
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini

# Ollama: URL que ve tu proceso (Jupyter local → localhost; Compose → http://ollama:11434;
# otra máquina en la red → http://ip-o-hostname:11434)
OLLAMA_BASE_URL=http://ollama:11434
# Mismo nombre que `ollama list` (suele incluir :latest)
OLLAMA_MODEL=llama3.2:latest
